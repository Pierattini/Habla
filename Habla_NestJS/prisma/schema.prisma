generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Availability {
  id             String       @id @default(uuid())
  professionalId String
  day            WeekDay
  scheduleMode   ScheduleMode @default(CONTINUOUS)
  startMinute    Int
  endMinute      Int
  breakMinute    Int          @default(0)
  specificSlots  Json?
  blockedRanges  Json?
  createdAt      DateTime     @default(now())
  professional   User         @relation(fields: [professionalId], references: [id])

  @@index([professionalId, day])
}

model User {
  id                     String    @id @default(uuid())
  email                  String    @unique
  name                   String?
  image                  String?
  password               String
  role                   Role
  createdAt              DateTime  @default(now())
  isActive               Boolean   @default(false)
  deletionRequestedAt    DateTime?
  deletedAt              DateTime?
  sessionDuration        Int?
  passwordResetTokenHash String?
  passwordResetExpiresAt DateTime?

  country  String?
  timezone String? @default("America/Santiago")

  taxId                     String?
  taxName                   String?
  taxEmail                  String?
  taxAddress                String?
  taxCountry                String?
  taxCity                   String?
  taxDocumentNote           String?
  wantsTaxDocumentByDefault Boolean            @default(false)
  customerInterests         String[]           @default([])
  preferredAttentionMode    AttentionModality?
  preferredCity             String?
  preferredRegion           String?

  customerAppointments            Appointment[]        @relation("CustomerAppointments")
  professionalAppointments        Appointment[]        @relation("ProfessionalAppointments")
  customerReviews                 Review[]             @relation("CustomerReviews")
  professionalReviews             Review[]             @relation("ProfessionalReviews")
  customerAppointmentRequests     AppointmentRequest[] @relation("CustomerAppointmentRequests")
  professionalAppointmentRequests AppointmentRequest[] @relation("ProfessionalAppointmentRequests")
  availabilities                  Availability[]
  professional                    Professional?
  deviceTokens                    UserDeviceToken[]

  customerConversations     Conversation[]                      @relation("CustomerConversations")
  professionalConversations Conversation[]                      @relation("ProfessionalConversations")
  sentMessages              Message[]                           @relation("SentMessages")
  supportTicketsAsCustomer  SupportTicket[]                     @relation("SupportTicketCustomer")
  supportTicketsAsAdmin     SupportTicket[]                     @relation("SupportTicketAdmin")
  taxProviderCredentials    ProfessionalTaxProviderCredential[] @relation("ProfessionalTaxProviderCredentials")
  taxFolioRanges            ProfessionalTaxFolioRange[]         @relation("ProfessionalTaxFolioRanges")

  credit Float @default(0)
}

model Appointment {
  id                 String            @id @default(uuid())
  date               DateTime
  status             AppointmentStatus @default(PENDING)
  customerId         String
  professionalId     String
  createdAt          DateTime          @default(now())
  rescheduleCount    Int               @default(0)
  paidAt             DateTime?
  bookedEmailSentAt  DateTime?
  sameDayEmailSentAt DateTime?
  sameDayPushSentAt  DateTime?
  reminder24hSentAt  DateTime?
  reminder1hSentAt   DateTime?
  reminder15mSentAt  DateTime?

  // 🔥 PENALIZACIÓN
  penalty         Float?
  penaltyResolved Boolean @default(false)
  penaltyOption   String? // 'REFUND' | 'CREDIT'

  // 🔥 CRÉDITO / PAGO
  creditUsed     Float? // cuánto crédito se usó
  remainingToPay Float? // cuánto falta pagar

  paymentConfirmTokenHash      String?
  paymentConfirmTokenExpiresAt DateTime?
  paymentConfirmTokenUsedAt    DateTime?

  // 🔥 REEMBOLSO
  refundAccount String?
  refundBank    String?
  refundDoneTokenHash      String?
  refundDoneTokenExpiresAt DateTime?
  refundDoneTokenUsedAt    DateTime?

  // 🔥 OTROS
  meetLink             String?
  meetingProvider      VideoProvider?
  meetingUrl           String?
  meetingId            String?
  meetingAccessToken   String?
  meetingCreatedAt     DateTime?
  calendarEventId      String?
  attentionMode        AttentionModality @default(ONLINE)
  appointmentAddress   String?
  appointmentCity      String?
  appointmentRegion    String?
  appointmentCountry   String?
  appointmentLatitude  Float?
  appointmentLongitude Float?
  arrivalInstructions  String?
  videoProvider        VideoProvider?

  documentRequested   Boolean        @default(false)
  documentStatus      DocumentStatus @default(DOCUMENT_NOT_REQUIRED)
  documentRequestedAt DateTime?
  documentSentAt      DateTime?
  documentAmount      Int?
  documentCurrency    String         @default("CLP")

  customer     User @relation("CustomerAppointments", fields: [customerId], references: [id])
  professional User @relation("ProfessionalAppointments", fields: [professionalId], references: [id])

  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  conversationId String?
  taxDocument    TaxDocument?
  review         Review?
}

model Review {
  id             String   @id @default(uuid())
  appointmentId  String   @unique
  customerId     String
  professionalId String
  rating         Int
  comment        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  appointment  Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  customer     User        @relation("CustomerReviews", fields: [customerId], references: [id])
  professional User        @relation("ProfessionalReviews", fields: [professionalId], references: [id])

  @@index([customerId])
  @@index([professionalId])
  @@index([rating])
  @@index([createdAt])
}

model ProfessionalCategory {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  description String?
  icon        String?
  sortOrder   Int          @default(0)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  professions Profession[]

  @@index([isActive, sortOrder])
}

model Profession {
  id            String               @id @default(uuid())
  categoryId    String
  name          String
  slug          String               @unique
  aliases       String[]             @default([])
  icon          String?
  sortOrder     Int                  @default(0)
  isActive      Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  category      ProfessionalCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  professionals Professional[]

  @@index([categoryId, isActive, sortOrder])
  @@index([isActive, sortOrder])
}

model Professional {
  id     String  @id @default(uuid())
  userId String  @unique
  user   User    @relation(fields: [userId], references: [id])
  slug   String? @unique

  professionId        String?
  profession          Profession?       @relation(fields: [professionId], references: [id])
  customProfession    String?
  specialty           String?
  description         String?
  rules               String?
  name                String?
  price               Int?
  duration            Int?
  isOnline            Boolean?          @default(true)
  image               String?
  attentionMode       AttentionModality @default(ONLINE)
  officeAddress       String?
  officeCity          String?
  officeRegion        String?
  officeCountry       String?
  officeLatitude      Float?
  officeLongitude     Float?
  arrivalInstructions String?
  videoProvider       VideoProvider     @default(CONNECTA_AUTO)
  customVideoUrl      String?

  // Datos Bancarios
  bankName      String?
  accountType   String?
  accountNumber String?
  accountHolder String?
  accountEmail  String?

  documentAutomationEnabled Boolean      @default(false)
  manualDocumentMode        Boolean      @default(true)
  taxProvider               TaxProvider?
  taxId                     String?
  taxName                   String?
  taxEmail                  String?
  taxAddress                String?
  taxCountry                String?
  taxCity                   String?
  taxDocumentNote           String?

  // Suscripción Conecta
  planStatus          ProfessionalPlanStatus @default(FREE)
  firstLeadReceivedAt DateTime?
  subscriptionStartAt DateTime?
  subscriptionEndAt   DateTime?

  profileEvents        ProfessionalProfileEvent[]
  subscription         ProfessionalSubscription?
  subscriptionPayments ProfessionalSubscriptionPayment[]

  @@index([professionId])
  @@index([attentionMode])
}

model ProfessionalSubscription {
  id                     String                         @id @default(uuid())
  professionalId         String                         @unique
  status                 ProfessionalSubscriptionStatus @default(TRIAL)
  provider               SubscriptionProvider?
  providerSubscriptionId String?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  autoRenew              Boolean                        @default(false)
  cancelledAt            DateTime?
  lastPaymentAt          DateTime?
  createdAt              DateTime                       @default(now())
  updatedAt              DateTime                       @updatedAt

  professional Professional                      @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  payments     ProfessionalSubscriptionPayment[]

  @@index([status])
  @@index([currentPeriodEnd])
}

model ProfessionalSubscriptionPayment {
  id                String                    @id @default(uuid())
  professionalId    String
  subscriptionId    String?
  provider          SubscriptionProvider
  providerPaymentId String?
  amount            Int
  currency          String                    @default("CLP")
  status            SubscriptionPaymentStatus
  paidAt            DateTime?
  rawPayload        Json?
  createdAt         DateTime                  @default(now())

  professional Professional              @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  subscription ProfessionalSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([professionalId])
  @@index([subscriptionId])
  @@index([status])
  @@index([createdAt])
}

model AppointmentRequest {
  id                     String                   @id @default(uuid())
  customerId             String
  professionalId         String
  requestedDate          DateTime?
  requestedMode          AttentionModality?
  message                String?
  status                 AppointmentRequestStatus @default(PENDING)
  unlockedAt             DateTime?
  convertedAppointmentId String?
  conversationId         String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  customer     User          @relation("CustomerAppointmentRequests", fields: [customerId], references: [id])
  professional User          @relation("ProfessionalAppointmentRequests", fields: [professionalId], references: [id])
  conversation Conversation? @relation(fields: [conversationId], references: [id])

  @@index([customerId])
  @@index([professionalId])
  @@index([status])
  @@index([conversationId])
  @@index([createdAt])
}

model ProfessionalProfileEvent {
  id             String           @id @default(uuid())
  professionalId String
  type           ProfileEventType
  createdAt      DateTime         @default(now())

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId])
  @@index([type])
  @@index([createdAt])
}

model GoogleCalendarConnection {
  id                    String    @id @default(uuid())
  professionalUserId    String    @unique
  googleAccountId       String
  googleEmail           String
  encryptedAccessToken  String
  encryptedRefreshToken String?
  tokenExpiresAt        DateTime?
  connectedAt           DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([professionalUserId])
}

model ZoomConnection {
  id                    String    @id @default(uuid())
  professionalUserId    String    @unique
  zoomUserId            String
  zoomEmail             String
  encryptedAccessToken  String
  encryptedRefreshToken String?
  tokenExpiresAt        DateTime?
  connectedAt           DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([professionalUserId])
}

model MicrosoftTeamsConnection {
  id                    String    @id @default(uuid())
  professionalUserId    String    @unique
  microsoftAccountId    String
  microsoftEmail        String
  encryptedAccessToken  String
  encryptedRefreshToken String?
  tokenExpiresAt        DateTime?
  connectedAt           DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([professionalUserId])
}

model NotificationLog {
  id            String   @id @default(uuid())
  type          String
  channel       String
  status        String
  provider      String?
  reason        String?
  recipientHash String?
  createdAt     DateTime @default(now())

  @@index([type, channel])
  @@index([createdAt])
}

model UserDeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([platform])
}

enum ProfileEventType {
  VIEW
  COPY_LINK
  SHARE
}

model Conversation {
  id             String @id @default(uuid())
  customerId     String
  professionalId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer     User @relation("CustomerConversations", fields: [customerId], references: [id])
  professional User @relation("ProfessionalConversations", fields: [professionalId], references: [id])

  messages            Message[]
  appointments        Appointment[]
  appointmentRequests AppointmentRequest[]
  supportTickets      SupportTicket[]

  @@unique([customerId, professionalId])
  @@index([customerId])
  @@index([professionalId])
}

model SupportTicket {
  id             String              @id @default(uuid())
  conversationId String
  customerId     String
  adminId        String
  status         SupportTicketStatus @default(OPEN)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  closedAt       DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  customer     User         @relation("SupportTicketCustomer", fields: [customerId], references: [id])
  admin        User         @relation("SupportTicketAdmin", fields: [adminId], references: [id])

  @@index([conversationId])
  @@index([customerId])
  @@index([adminId])
  @@index([status])
  @@index([conversationId, status])
}

model Message {
  id             String @id @default(uuid())
  conversationId String
  senderId       String

  content String?

  fileUrl      String?
  fileName     String?
  fileType     String?
  fileSize     Int?
  filePublicId String?

  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentMessages", fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

model TaxDocument {
  id            String @id @default(uuid())
  appointmentId String @unique

  status DocumentStatus   @default(DOCUMENT_PENDING)
  mode   DocumentMode     @default(MANUAL)
  type   TaxDocumentType?

  amount   Int?
  currency String @default("CLP")

  customerTaxId      String?
  customerTaxName    String?
  customerTaxEmail   String?
  customerTaxAddress String?
  customerTaxCountry String?
  customerTaxCity    String?
  customerTaxPhone   String?
  customerTaxComment String?

  professionalTaxId      String?
  professionalTaxName    String?
  professionalTaxEmail   String?
  professionalTaxAddress String?
  professionalTaxCountry String?
  professionalTaxCity    String?
  professionalTaxNote    String?

  provider           TaxProvider?
  providerDocumentId String?
  providerPayload    Json?
  providerResponse   Json?

  pdfUrl             String?
  pdfPublicId        String?
  xmlUrl             String?
  xmlPublicId        String?
  dteCode            Int?
  folio              String?
  siiTrackId         String?
  siiStatus          String?
  siiStatusDetail    String?
  lastProviderSyncAt DateTime?
  fileName           String?
  localFilePath      String?

  uploadedById String?
  generatedAt  DateTime?
  uploadedAt   DateTime?
  emailSent    Boolean   @default(false)
  emailSentAt  DateTime?
  sentAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  appointment Appointment        @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  events      TaxDocumentEvent[]

  @@index([status])
  @@index([provider])
}

model TaxDocumentEvent {
  id         String   @id @default(uuid())
  documentId String
  actorId    String?
  type       String
  message    String?
  metadata   Json?
  createdAt  DateTime @default(now())

  document TaxDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([actorId])
  @@index([createdAt])
}

model TaxDocumentJob {
  id            String               @id @default(uuid())
  appointmentId String
  documentId    String?
  type          String               @default("LIBREDTE_AUTO_ISSUE")
  status        TaxDocumentJobStatus @default(PENDING)
  attempts      Int                  @default(0)
  maxAttempts   Int                  @default(3)
  nextRunAt     DateTime             @default(now())
  startedAt     DateTime?
  finishedAt    DateTime?
  durationMs    Int?
  lockedAt      DateTime?
  lockToken     String?
  errorCode     String?
  errorMessage  String?
  errorPayload  Json?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@unique([appointmentId, type])
  @@index([status, nextRunAt])
  @@index([documentId])
  @@index([lockedAt])
}

model ProfessionalTaxProviderCredential {
  id                           String                      @id @default(uuid())
  professionalId               String
  provider                     TaxProvider                 @default(SII)
  rut                          String
  encryptedApiToken            String?
  encryptedCertificate         String?
  encryptedCertificatePassword String?
  certificateFileName          String?
  certificateMimeType          String?
  certificateFingerprint       String?
  certificateUploadedAt        DateTime?
  environment                  String                      @default("PRODUCTION")
  status                       TaxProviderCredentialStatus @default(CONFIGURED)
  lastValidatedAt              DateTime?
  createdAt                    DateTime                    @default(now())
  updatedAt                    DateTime                    @updatedAt

  professional User @relation("ProfessionalTaxProviderCredentials", fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([professionalId, provider])
  @@index([provider, status])
  @@index([professionalId])
}

model ProfessionalTaxFolioRange {
  id              String   @id @default(uuid())
  professionalId  String
  provider        TaxProvider @default(SII)
  dteCode         Int
  startFolio      Int
  endFolio        Int
  nextFolio       Int
  encryptedCafXml String
  cafFileName     String?
  cafFingerprint  String?
  status          String   @default("ACTIVE")
  uploadedAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  professional User @relation("ProfessionalTaxFolioRanges", fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([professionalId, provider, dteCode, startFolio, endFolio])
  @@index([professionalId, provider, dteCode, status])
  @@index([professionalId])
}

enum Role {
  CUSTOMER
  PROFESSIONAL
  ADMIN
}

enum WeekDay {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

enum ScheduleMode {
  CONTINUOUS
  SPECIFIC
}

enum AppointmentStatus {
  PENDING
  PENDING_PAYMENT
  PAYMENT_REVIEW
  CONFIRMED
  COMPLETED
  CANCELLED
  RESCHEDULED
  REFUNDED
}

enum AttentionModality {
  ONLINE
  PRESENTIAL
  BOTH
}

enum VideoProvider {
  CONNECTA_AUTO
  JITSI
  GOOGLE_MEET
  ZOOM
  MICROSOFT_TEAMS
  CUSTOM
}

enum DocumentStatus {
  DOCUMENT_NOT_REQUIRED
  DOCUMENT_PENDING
  DOCUMENT_UPLOADED
  DOCUMENT_GENERATED
  DOCUMENT_SENT
  DOCUMENT_FAILED
  DOCUMENT_CANCELLED
}

enum TaxDocumentJobStatus {
  PENDING
  PROCESSING
  RETRY
  COMPLETED
  FAILED
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum DocumentMode {
  MANUAL
  AUTOMATED
}

enum TaxProvider {
  SII
  LIBREDTE
  AEAT
  QUIPU
  HOLDED
  NUBOX
}

enum TaxProviderCredentialStatus {
  CONFIGURED
  INVALID
  DISABLED
}

enum ProfessionalPlanStatus {
  FREE
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum ProfessionalSubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum SubscriptionProvider {
  MERCADO_PAGO
  FLOW
  WEBPAY
  MANUAL
}

enum SubscriptionPaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

enum AppointmentRequestStatus {
  PENDING
  LOCKED_PENDING_SUBSCRIPTION
  ACCEPTED
  REJECTED
  EXPIRED
  CANCELLED
}

enum TaxDocumentType {
  BOLETA
  FACTURA
  INVOICE
  RECEIPT
}
